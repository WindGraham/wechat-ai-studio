{
  "manifest_version": 3,
  "name": "秀米选区本地保存",
  "short_name": "Xiumi Capture",
  "version": "1.0.0",
  "description": "捕获当前页面选中的富文本 HTML，并发送到本地 save-layout-server.py 保存。",

  "permissions": ["activeTab", "scripting", "storage", "tabs"],

  "host_permissions": [
    "https://xiumi.us/*",
    "https://*.xiumi.us/*",
    "http://localhost:8081/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "保存当前选区到本地"
  },

  "options_page": "options/options.html",

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "保存当前页面选区到本地"
    }
  }
}
