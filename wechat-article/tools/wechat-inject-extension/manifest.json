{
  "manifest_version": 3,
  "name": "微信图文跨站注入",
  "short_name": "WeChat Inject",
  "version": "1.0.0",
  "description": "将当前页面 HTML（含 SVG 动画）无损注入到微信公众号后台编辑器。",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": ["tabs", "scripting", "activeTab", "alarms"],

  "host_permissions": ["https://mp.weixin.qq.com/*"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://mp.weixin.qq.com/cgi-bin/appmsg*"],
      "js": ["content_scripts/sink.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "注入到微信公众号",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
